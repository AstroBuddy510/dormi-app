{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [

    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/grocery-app/dist/public/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/grocery-app/dist/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}