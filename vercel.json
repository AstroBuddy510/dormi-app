{
  "version": 2,
  "functions": {
    "api/handler.mjs": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler.mjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/grocery-app/dist/public/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/grocery-app/dist/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}